# Shared ignore rules for the public repo.
# For local-only untracked clutter, use .git/info/exclude (sample: docs/git-info-exclude.sample).
.github/workflows/refactor_quick_gate.yml
**/__pycache__/
*.pyc
*.pyo
*.pyd
*.npz
*.npy
*.pt
.env
.venv
.ipynb_checkpoints/
build/
dist/
site/assets/
.kwavedata/
figs/outputs/
runs/
reports/
data/
.pytest_cache/
.ruff_cache/
figs/paper/
mace_bridge/
tmp/
patent/
provisional_patent_draft_specification.md
provisional_patent_outline.md
LATENCY_OPTIMIZATION_SPEC.md
build_context.sh
docs/refactor/
docs/pymust_simus_clin_plan.md
docs/simulation_spec_plan.md
docs/simus_clinutility_v2_plan.md
notebooks/colab_play.ipynb
pymust_spec.txt
*.aux
*.fdb_latexmk
*.fls
*.log
*.out
*.synctex.gz
pymust_specv2.md

# Large run outputs (tracked via LFS or archived)
runs/motion/r4c/mcsvd_k8_reg4_stride2_seed*/

# Curated, paper-critical reproducibility artifacts (keep the rest of reports/ ignored).
!reports/
reports/**
!reports/latency/
!reports/latency/4080super_latency_summary.csv
!reports/latency/4080super_latency_summary.json

# Physical Doppler sanity-link (SIMUS/PyMUST) Phase 3 artifacts.
!reports/physdoppler_sanity_link/
!reports/physdoppler_sanity_link/simus_*.json

# SIMUS baseline vs STAP comparisons (paper-style baselines on SIMUS Icube).
!reports/simus_baseline_compare/
!reports/simus_baseline_compare/*.csv
!reports/simus_baseline_compare/*.json
